# Alebus API - Production Environment Template
#
# Copy to your deployment secret manager / env injection.
# DO NOT COMMIT REAL SECRETS.

# --- Required ---
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# --- Network ---
# Prefer API_PORT; PORT is supported for platforms like Heroku.
API_PORT=8080
#PORT=8080

# --- Auth (recommended: bearer) ---
API_AUTH_MODE=bearer
API_AUTH_BYPASS=false

# Public token (end-user / general API). Required when auth is on.
API_BEARER_TOKEN=REPLACE_ME

# Scoped tokens (recommended)
API_OPS_BEARER_TOKEN=REPLACE_ME
API_ADMIN_BEARER_TOKEN=REPLACE_ME

# Alternative auth mode (if you switch API_AUTH_MODE=api_key)
#API_API_KEY=REPLACE_ME
#API_OPS_API_KEY=REPLACE_ME
#API_ADMIN_API_KEY=REPLACE_ME

# --- Dev endpoints MUST be off in production ---
ENABLE_DEV_ENDPOINTS=false

# --- Stream authorization (required for production) ---
# off | warn | enforce
STREAM_AUTH_ENFORCEMENT=enforce
BACKWARD_COMPATIBLE_STREAM_AUTH=false

# --- WebSocket Origin allowlist (browser security) ---
# Comma-separated exact origins (scheme + host + optional port)
# Example:
# WS_ALLOWED_ORIGINS=https://ops.example.com,https://admin.example.com
WS_ALLOWED_ORIGINS=

# --- CORS (REST endpoints) ---
# If you have browser apps calling REST cross-origin, set this allowlist.
# Example:
# CORS_ALLOWED_ORIGINS=https://ops.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=

# --- Proxy / load balancer ---
# Only set if the API is behind a trusted reverse proxy (nginx/ALB/etc).
# Comma-separated IPs or CIDRs.
# Example:
# TRUSTED_PROXIES=10.0.0.0/8,192.168.0.0/16
TRUSTED_PROXIES=

# --- Security headers ---
SECURITY_HEADERS_ENABLED=true

# --- Request limits ---
# Default is 15MB; tune as needed.
API_MAX_BODY_BYTES=15728640

# --- Connection limits (tune per instance capacity) ---
API_SSE_MAX_CONNECTIONS_OPS=2000
API_SSE_MAX_CONNECTIONS_PUB=4000
API_WS_MAX_CONNECTIONS_OPS=2000
API_WS_MAX_CONNECTIONS_PUB=4000
API_WS_MAX_CONNECTIONS_MUX=4000

# --- Optional: Push notifications ---
#EXPO_PUSH_ACCESS_TOKEN=

# --- Optional: MQTT raw GPS publisher (should typically be empty in prod) ---
#MQTT_BROKER_URL=
#MQTT_CLIENT_ID=
#MQTT_USERNAME=
#MQTT_PASSWORD=
